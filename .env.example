# Copy to .env and fill in your Atlas connection string.
# If the password contains @ # : / ? etc., URL-encode it (e.g. @ -> %40, # -> %23).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority&appName=YOUR_APP
MONGODB_DB_NAME=vexora

# --- Contact form email (nodemailer) — use ONE approach ---

# Option A: Gmail (enable 2FA, create an App Password)
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option B: Any SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=secret

# Optional overrides (defaults: MAIL_FROM = SMTP_USER or GMAIL_USER, MAIL_TO = MAIL_FROM)
# MAIL_FROM=Vexor Site <hello@example.com>
# MAIL_TO=inbox@example.com
