# Copy to .env and fill in your Atlas connection string.
# If the password contains @ # : / ? etc., URL-encode it (e.g. @ -> %40, # -> %23).
MONGODB_URI=your_mongodb_connection_string_here
MONGODB_DB_NAME=your_db_name_here

# --- Contact form email (EmailJS) ---
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ADMIN=your_emailjs_admin_template_id_here
EMAILJS_TEMPLATE_USER=your_emailjs_user_template_id_here
MAIL_TO=admin@example.com

# --- Contact form email (nodemailer) — use ONE approach ---

# Option A: Gmail (enable 2FA, create an App Password)
GMAIL_USER=your_gmail_email_here
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Option B: Any SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=secret

# Optional overrides (defaults: MAIL_FROM = SMTP_USER or GMAIL_USER, MAIL_TO = MAIL_FROM)
# MAIL_FROM=Vexor Site <hello@example.com>

# --- Admin Authentication ---
ADMIN_EMAIL=your_admin_email_here
ADMIN_PASSWORD=your_admin_password_here
