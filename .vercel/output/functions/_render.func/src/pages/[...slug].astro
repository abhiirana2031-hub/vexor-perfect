---
// This file handles all routes and delegates to the React router
import { Head } from "@/components/Head";
import AppRouter from "@/components/Router";
import "@/styles/global.css";

export const prerender = false;
---

<html lang="en" class="w-full h-full">
  <head>
    <Head />
    <meta charset="utf-8" />
    <title>Vexor IT Solutions - Transform Your Business</title>
  </head>
  <body class="w-full h-full overflow-x-hidden">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>
    <script>
      // Ensure root div is properly sized
      document.documentElement.style.height = '100%';
      document.body.style.height = '100%';
      const root = document.getElementById('root');
      if (root) {
        root.style.height = '100%';
        root.style.width = '100%';
      }
    </script>
  </body>
</html>
