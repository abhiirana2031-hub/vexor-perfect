---
// This file handles all routes and delegates to the React router
import { Head } from "@/components/Head";
import AppRouter from "@/components/Router";
import "@/styles/global.css";
import { pwaInfo } from 'virtual:pwa-info';

export const prerender = false;
---

<html lang="en" class="w-full">
  <head>
    <Head />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    <meta charset="utf-8" />
    <title>Vexor IT Solutions - Transform Your Business</title>
    <meta name="theme-color" content="#000000" />
  </head>
  <body class="w-full overflow-x-hidden">
    <div id="root" class="w-full">
      <AppRouter client:only="react" />
    </div>
    <script>
      // Ensure root div is properly sized
      const root = document.getElementById('root');
      if (root) root.style.width = '100%';
    </script>
  </body>
</html>
